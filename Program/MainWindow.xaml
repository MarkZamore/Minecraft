<Window x:Class="Minecraft.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Minecraft"
        Title="Minecraft" Height="460" Width="520" MinHeight="460" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        Icon="Minecraft.ico" Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="VoiceMutedBrush" Color="#C93636"/>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlDisabledBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlDisabledBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ProgressIdleBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="ProgressFrameStyle" TargetType="Border">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlDisabledBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <DataTemplate x:Key="BuildItemTemplate">
            <TextBlock Text="{Binding Name}" TextAlignment="Center" HorizontalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate x:Key="WorldItemTemplate">
            <TextBlock Text="{Binding DisplayName}" TextAlignment="Center" HorizontalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate x:Key="PeerItemTemplate">
            <TextBlock Text="{Binding DisplayName}" TextAlignment="Center" HorizontalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate x:Key="NetworkProviderItemTemplate">
            <TextBlock Text="{Binding DisplayName}" TextAlignment="Center" HorizontalAlignment="Stretch"/>
        </DataTemplate>
        <DataTemplate x:Key="VoicePeerTemplate">
            <TextBlock Text="{Binding VoiceDisplayName}" TextAlignment="Left"
                       HorizontalAlignment="Stretch" Margin="6,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource ProgressActiveBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsVoiceMuted}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource VoiceMutedBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>
    </Window.Resources>

    <Viewbox Stretch="Uniform" StretchDirection="Both">
        <Grid x:Name="RootGrid" Width="820" Height="700" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="72"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Имя"/>
                <TextBox Grid.Column="1" x:Name="PlayerNameTextBox"
                         MaxLength="16"
                         IsReadOnly="True"
                         TextChanged="PlayerNameTextBox_TextChanged"
                         PreviewTextInput="PlayerNameTextBox_PreviewTextInput"
                         DataObject.Pasting="PlayerNameTextBox_Pasting"
                         LostFocus="PlayerNameTextBox_LostFocus"
                         KeyDown="PlayerNameTextBox_KeyDown"
                         Margin="8,0,6,0"/>
                <Button Grid.Column="2" x:Name="ChangePlayerNameButton"
                        Content="Изменить" Click="ChangePlayerNameButton_Click"
                        MinWidth="72" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="Сборка"/>
                <local:CenteredDropDown Grid.Column="4" x:Name="BuildComboBox"
                                        ItemTemplate="{StaticResource BuildItemTemplate}"
                                        SelectionChanged="BuildComboBox_SelectionChanged"
                                        Margin="8,0,0,0"/>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="PlayButton" Content="Играть" Click="PlayButton_Click"
                        MinHeight="38" FontSize="16" FontWeight="SemiBold"/>
                <Button Grid.Column="1" x:Name="SkinButton" Content="Скин" Click="SkinButton_Click"
                        MinHeight="38" MinWidth="68" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="2" Text="RAM" Margin="12,0,6,0"/>
                <TextBox Grid.Column="3" x:Name="MemoryTextBox" TextAlignment="Center" FontSize="16"
                         PreviewTextInput="MemoryTextBox_PreviewTextInput"
                         TextChanged="MemoryTextBox_TextChanged"
                         DataObject.Pasting="MemoryTextBox_Pasting"
                         LostFocus="MemoryTextBox_LostFocus" KeyDown="MemoryTextBox_KeyDown"/>
                <TextBlock Grid.Column="4" Text="GB" Margin="6,0,0,0"/>
            </Grid>

            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Голосовой чат" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                <Border Grid.Row="1" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="VoicePeersItemsControl"
                                      HorizontalContentAlignment="Stretch"
                                      ItemTemplate="{StaticResource VoicePeerTemplate}"/>
                    </ScrollViewer>
                </Border>
                <Grid Grid.Row="2" Margin="0,5,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="VoiceJoinButton" Content="&#xE717;" Width="30" Height="28" Padding="0"
                                FontFamily="Segoe Fluent Icons" FontSize="15" ToolTip="Войти в голосовой канал"
                                Click="VoiceJoinButton_Click"/>
                        <Button x:Name="VoiceMuteButton" Content="&#xE720;" Width="30" Height="28" Padding="0"
                                FontFamily="Segoe Fluent Icons" FontSize="14" ToolTip="Выключить микрофон" Margin="5,0,0,0"
                                Click="VoiceMuteButton_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="VoiceProtectionButton" Content="&#xEA18;" Width="30" Height="28"
                                Padding="0" FontFamily="Segoe Fluent Icons" FontSize="14"
                                ToolTip="Буфер включён" Click="VoiceProtectionButton_Click"/>
                        <Button x:Name="VoiceSettingsButton" Content="&#xE713;" Width="30" Height="28"
                                Padding="0" Margin="5,0,0,0"
                                FontFamily="Segoe Fluent Icons" FontSize="14"
                                ToolTip="Настройки голосового чата"
                                Click="VoiceSettingsButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,10">
                <TextBlock Text="Hamachi" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="InstallNetworkToolButton" Content="Установить"
                            Click="InstallNetworkToolButton_Click" Margin="0,0,8,0" MinWidth="92"/>
                    <Button Grid.Column="1" x:Name="GenerateNetworkCredentialsButton" Content="Генерировать"
                            Click="GenerateNetworkCredentialsButton_Click" Margin="0,0,8,0" MinWidth="108"/>
                    <Grid Grid.Column="2">
                        <local:CenteredDropDown x:Name="NetworkProviderComboBox"
                                                ItemTemplate="{StaticResource NetworkProviderItemTemplate}"
                                                SelectionChanged="NetworkProviderComboBox_SelectionChanged"/>
                        <TextBlock x:Name="NetworkProviderPlaceholderText"
                                   Text="VPN не найден"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Сеть"/>
                    <TextBox Grid.Column="1" x:Name="NetworkNameTextBox" IsReadOnly="True"/>
                    <Button Grid.Column="2" x:Name="CopyNetworkNameButton" Content="Копировать"
                            Click="CopyNetworkNameButton_Click" Margin="8,0,0,0" MinWidth="88"/>
                </Grid>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Пароль"/>
                    <TextBox Grid.Column="1" x:Name="NetworkPasswordTextBox" IsReadOnly="True"/>
                    <Button Grid.Column="2" x:Name="CopyNetworkPasswordButton" Content="Копировать"
                            Click="CopyNetworkPasswordButton_Click" Margin="8,0,0,0" MinWidth="88"/>
                </Grid>
                <CheckBox x:Name="NetworkToolAutoLaunchCheckBox" Content="Автозапуск"
                          Checked="NetworkToolAutoLaunchCheckBox_Changed"
                          Unchecked="NetworkToolAutoLaunchCheckBox_Changed"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,6">
                <TextBlock Text="Передача мира" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Мир"/>
                    <Grid Grid.Column="1">
                        <local:CenteredDropDown x:Name="WorldComboBox"
                                                ItemTemplate="{StaticResource WorldItemTemplate}"
                                                SelectionChanged="WorldComboBox_SelectionChanged"/>
                        <TextBlock x:Name="WorldPlaceholderText"
                                   Text="Нет миров для передачи"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   HorizontalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Игрок"/>
                    <Grid Grid.Column="1">
                        <local:CenteredDropDown x:Name="OnlinePlayerComboBox"
                                                ItemTemplate="{StaticResource PeerItemTemplate}"
                                                SelectionChanged="TransferSelectionChanged"/>
                        <TextBlock x:Name="OnlinePlayerPlaceholderText"
                                   Text="Нет игроков в сети"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   HorizontalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" MinHeight="28">
                    <Border Style="{StaticResource ProgressFrameStyle}">
                        <ProgressBar x:Name="TransferProgressBar" Minimum="0" Maximum="100"
                                     Foreground="{StaticResource ProgressIdleBrush}"/>
                    </Border>
                    <TextBlock x:Name="TransferProgressText" Text="В ожидании мира"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
                <Button Grid.Column="1" x:Name="TransferButton" Content="Передать"
                        Click="TransferButton_Click" Margin="8,0,0,0" MinWidth="88"/>
            </Grid>

            <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" MinHeight="28">
                    <Border Style="{StaticResource ProgressFrameStyle}">
                        <ProgressBar x:Name="UpdateProgressBar" Minimum="0" Maximum="100"
                                     Foreground="{StaticResource ProgressIdleBrush}"/>
                    </Border>
                    <TextBlock x:Name="UpdateProgressText" Text="Вы на последней версии"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
                <Button Grid.Column="1" x:Name="UpdateButton" Content="Обновить"
                        Click="UpdateButton_Click" Margin="8,0,0,0" MinWidth="88" IsEnabled="False"/>
            </Grid>

            <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,6"
                  ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource ProgressFrameStyle}">
                    <ProgressBar x:Name="SecretProgressBar" Minimum="0" Maximum="100"
                                 Foreground="{StaticResource ProgressIdleBrush}"/>
                </Border>
                <Button Grid.Column="1" x:Name="SecretOpenButton" Content="Открыть"
                        Click="SecretOpenButton_Click" Margin="8,0,0,0" MinWidth="88" IsEnabled="False"/>
                <ProgressBar Grid.Column="0" Grid.ColumnSpan="2"
                             x:Name="SecretExtendedProgressBar"
                             Minimum="0" Maximum="600" Height="28"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource ProgressActiveBrush}"
                             IsHitTestVisible="False" Panel.ZIndex="2"/>
                <TextBlock Grid.Column="0" x:Name="SecretProgressText" Text="Загрузка"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Panel.ZIndex="3"/>
            </Grid>

            <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,8">
                <Border Style="{StaticResource ProgressFrameStyle}">
                    <ProgressBar x:Name="RuntimeProgressBar" Minimum="0" Maximum="100"
                                 Foreground="{StaticResource ProgressIdleBrush}"/>
                </Border>
                <TextBlock x:Name="RuntimeProgressText" Text="В ожидании игры"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>

            <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="10">
                <TextBlock Text="AI-помощник обученный на вашей сборке Minecraft"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="15" FontWeight="SemiBold" Margin="10,10,10,46"/>
            </Grid>
            <Grid Grid.Column="2" Grid.Row="8" Height="28"
                  Margin="0,0,0,8" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="82"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="Пока не работает :("
                         Height="28" IsReadOnly="True" IsEnabled="False" TextAlignment="Left"/>
                <Button Grid.Column="1" Content="Отправить" Height="28"
                        IsEnabled="False" Margin="6,0,0,0"/>
            </Grid>

            <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Лучше TLauncher" HorizontalAlignment="Left" FontSize="11"/>
            <TextBlock Grid.Row="9" Grid.Column="2" x:Name="VersionTextBlock"
                       HorizontalAlignment="Right" TextAlignment="Right" FontSize="11"/>

            <Grid Visibility="Collapsed">
                <ComboBox x:Name="HostComboBox" DisplayMemberPath="HostDisplayName"
                          SelectionChanged="HostComboBox_SelectionChanged"/>
                <TextBlock x:Name="PackHashText"/>
                <TextBlock x:Name="TransferStatusText"/>
                <TextBlock x:Name="VoiceStatusText"/>
                <TextBox x:Name="LogTextBox"/>
                <Button x:Name="VoicePttButton"/>
                <ComboBox x:Name="VoiceInputComboBox" SelectionChanged="VoiceInputComboBox_SelectionChanged"/>
                <ComboBox x:Name="VoiceOutputComboBox" SelectionChanged="VoiceOutputComboBox_SelectionChanged"/>
                <Slider x:Name="VoiceMasterVolumeSlider" Minimum="0" Maximum="2"
                        ValueChanged="VoiceMasterVolumeSlider_ValueChanged"/>
                <Button x:Name="VoiceDeafenButton" Click="VoiceDeafenButton_Click"/>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
