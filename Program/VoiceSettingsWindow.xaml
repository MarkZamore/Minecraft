<Window x:Class="Minecraft.VoiceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки голоса"
        Height="390"
        Width="430"
        MinHeight="300"
        MinWidth="330"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform" StretchDirection="Both">
        <Grid Width="390" Height="330" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Устройства" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ввод"/>
                    <ComboBox Grid.Column="1" x:Name="InputDeviceComboBox"
                              DisplayMemberPath="Name"
                              SelectionChanged="InputDeviceComboBox_SelectionChanged"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Вывод"/>
                    <ComboBox Grid.Column="1" x:Name="OutputDeviceComboBox"
                              DisplayMemberPath="Name"
                              SelectionChanged="OutputDeviceComboBox_SelectionChanged"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Режим рации" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Режим"/>
                    <ComboBox Grid.Column="1" x:Name="PttModeComboBox"
                              SelectionChanged="PttModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Выключен" Tag="Off"/>
                        <ComboBoxItem Content="Удержание" Tag="Hold"/>
                        <ComboBoxItem Content="По нажатию" Tag="Toggle"/>
                    </ComboBox>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Кнопка"/>
                    <Button Grid.Column="1" x:Name="PttBindingButton"
                            Click="PttBindingButton_Click"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Громкость" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ввод"/>
                    <Slider Grid.Column="1" x:Name="InputVolumeSlider"
                            Minimum="0"
                            Maximum="2"
                            TickFrequency="0.1"
                            ValueChanged="InputVolumeSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="InputVolumeText" TextAlignment="Right"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Вывод"/>
                    <Slider Grid.Column="1" x:Name="OutputVolumeSlider"
                            Minimum="0"
                            Maximum="2"
                            TickFrequency="0.1"
                            ValueChanged="OutputVolumeSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="OutputVolumeText" TextAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
