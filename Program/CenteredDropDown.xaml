<UserControl x:Class="Minecraft.CenteredDropDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ControlRoot"
             MinHeight="28"
             Focusable="False"
             PreviewKeyDown="ControlRoot_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="DropDownToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <ToggleButton x:Name="DropDownButton"
                      MinHeight="28"
                      Padding="0"
                      Background="{DynamicResource ControlSurfaceBrush}"
                      Style="{StaticResource DropDownToggleStyle}"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Stretch"
                      Checked="DropDownButton_Checked"
                      Unchecked="DropDownButton_Unchecked">
            <Grid>
                <ContentPresenter Content="{Binding SelectedItem, ElementName=ControlRoot}"
                                  ContentTemplate="{Binding ItemTemplate, ElementName=ControlRoot}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Margin="20,0"/>
                <TextBlock Text="⌄"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,7,2"
                           IsHitTestVisible="False"/>
            </Grid>
        </ToggleButton>

        <Popup x:Name="DropDownPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=DropDownButton}"
               StaysOpen="False"
               AllowsTransparency="True"
               Opened="DropDownPopup_Opened"
               Closed="DropDownPopup_Closed">
            <Border Width="{Binding ActualWidth, ElementName=ControlRoot}"
                    MaxHeight="260"
                    Background="{DynamicResource ControlSurfaceBrush}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1">
                <ListBox x:Name="ItemsList"
                         ItemsSource="{Binding ItemsSource, ElementName=ControlRoot}"
                         ItemTemplate="{Binding ItemTemplate, ElementName=ControlRoot}"
                         Background="{DynamicResource ControlSurfaceBrush}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         PreviewKeyDown="ControlRoot_PreviewKeyDown"
                         PreviewMouseLeftButtonUp="ItemsList_PreviewMouseLeftButtonUp"
                         SelectionChanged="ItemsList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="MinHeight" Value="28"/>
                            <Setter Property="Padding" Value="5,3"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</UserControl>
