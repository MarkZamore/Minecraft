{
  "schemaVersion": 1,
  "providers": [
    {
      "id": "hamachi",
      "displayName": "Hamachi",
      "clientProcesses": ["hamachi-2-ui"],
      "adapterPatterns": ["Hamachi", "LogMeIn Hamachi"]
    },
    {
      "id": "radmin",
      "displayName": "Radmin VPN",
      "clientProcesses": ["RadminVPN", "RvRvpnGui"],
      "adapterPatterns": ["Radmin VPN"]
    },
    {
      "id": "zerotier",
      "displayName": "ZeroTier",
      "clientProcesses": ["zerotier_desktop_ui", "ZeroTier One"],
      "adapterPatterns": ["ZeroTier"]
    },
    {
      "id": "tailscale",
      "displayName": "Tailscale",
      "clientProcesses": ["tailscale-ipn"],
      "adapterPatterns": ["Tailscale"],
      "peerSources": [
        {
          "executableNames": ["tailscale.exe", "%ProgramFiles%\\Tailscale\\tailscale.exe"],
          "arguments": "status --json"
        }
      ]
    },
    {
      "id": "netbird",
      "displayName": "NetBird",
      "clientProcesses": ["netbird-ui"],
      "adapterPatterns": ["NetBird", "WireGuard Tunnel: netbird"],
      "peerSources": [
        {
          "executableNames": ["netbird.exe", "%ProgramFiles%\\NetBird\\netbird.exe"],
          "arguments": "status --json"
        }
      ]
    },
    {
      "id": "easytier",
      "displayName": "EasyTier",
      "clientProcesses": ["easytier-gui", "easytier-manager", "easytier-core"],
      "adapterPatterns": ["EasyTier"],
      "peerSources": [
        {
          "executableNames": ["easytier-cli.exe", "easytier-cli"],
          "arguments": "peer"
        }
      ]
    },
    {
      "id": "nord-meshnet",
      "displayName": "NordVPN Meshnet",
      "clientProcesses": ["NordVPN"],
      "adapterPatterns": ["NordLynx", "NordVPN"]
    },
    {
      "id": "husarnet",
      "displayName": "Husarnet",
      "clientProcesses": ["husarnet-daemon", "husarnet"],
      "adapterPatterns": ["Husarnet"],
      "peerSources": [
        {
          "executableNames": ["husarnet.exe", "husarnet"],
          "arguments": "daemon whitelist ls"
        }
      ]
    }
  ]
}
